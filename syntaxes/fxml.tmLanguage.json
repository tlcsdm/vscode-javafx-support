{
    "name": "FXML",
    "scopeName": "source.fxml",
    "fileTypes": [
        "fxml"
    ],
    "patterns": [
        {
            "include": "#xml-decl"
        },
        {
            "include": "#language-decl"
        },
        {
            "include": "#import"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#cdata"
        },
        {
            "include": "#fx-attr"
        },
        {
            "include": "#event-handler-attr"
        },
        {
            "include": "#generic-attr"
        },
        {
            "include": "#property-tag"
        },
        {
            "include": "#generic-tags"
        }
    ],
    "repository": {
        "xml-decl": {
            "patterns": [
                {
                    "begin": "<\\?xml",
                    "end": "\\?>",
                    "name": "comment"
                }
            ]
        },
        "language-decl": {
            "patterns": [
                {
                    "begin": "<\\?language",
                    "end": "\\?>",
                    "name": "comment"
                }
            ]
        },
        "import": {
            "patterns": [
                {
                    "match": "(<\\?import\\s+)([a-zA-Z][a-zA-Z0-9.]+?)(\\*?)(\\?>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "keyword"
                        },
                        "3": {
                            "name": "keyword"
                        },
                        "4": {
                            "name": "comment"
                        }
                    }
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "match": "<!--.*?-->",
                    "name": "comment"
                },
                {
                    "begin": "<!--",
                    "end": "-->",
                    "name": "comment"
                }
            ]
        },
        "cdata": {
            "begin": "<!\\[CDATA\\[",
            "end": "\\]\\]>",
            "name": "string"
        },
        "fx-attr": {
            "patterns": [
                {
                    "match": "(fx:[a-zA-Z0-9]+)\\s*?(=)\\s*?(\"[^\"]*\")",
                    "captures": {
                        "1": {
                            "name": "keyword"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "string"
                        }
                    }
                }
            ]
        },
        "event-handler-attr": {
            "patterns": [
                {
                    "match": "(on[A-Z][a-zA-Z0-9]*)\\s*?(=)\\s*?(\"[^\"]*\")",
                    "captures": {
                        "1": {
                            "name": "support.function"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "string"
                        }
                    }
                }
            ]
        },
        "generic-attr": {
            "patterns": [
                {
                    "match": "([a-zA-Z0-9:.]+)\\s*?(=)\\s*?(\"[^\"]*\")",
                    "captures": {
                        "1": {
                            "name": "variable"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "string"
                        }
                    }
                }
            ]
        },
        "property-tag": {
            "patterns": [
                {
                    "match": "(<)(/?)([a-z][a-zA-Z0-9:._-]+?\\b[^>]*>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "entity.name.tag"
                        }
                    }
                }
            ]
        },
        "generic-tags": {
            "patterns": [
                {
                    "match": "(<)(/?)([A-Za-z][A-Za-z0-9:._-]+?/?>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "entity.name.type"
                        }
                    }
                },
                {
                    "match": "<[A-Z][A-Za-z0-9:._-]+?\\s",
                    "name": "entity.name.type"
                },
                {
                    "match": "(/?)(>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "comment"
                        }
                    }
                }
            ]
        }
    }
}

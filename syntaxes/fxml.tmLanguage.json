{
    "name": "FXML",
    "scopeName": "source.fxml",
    "fileTypes": [
        "fxml"
    ],
    "patterns": [
        { "include": "#xml-decl" },
        { "include": "#language-decl" },
        { "include": "#import" },
        { "include": "#comments" },
        { "include": "#cdata" },
        { "include": "#fx-attr" },
        { "include": "#event-handler-attr" },
        { "include": "#generic-attr" },
        { "include": "#fx-tag" },
        { "include": "#class-tag" },
        { "include": "#property-tag" },
        { "include": "#tag-punctuation" }
    ],
    "repository": {
        "xml-decl": {
            "begin": "<\\?xml\\b",
            "end": "\\?>",
            "name": "comment"
        },
        "language-decl": {
            "begin": "<\\?language\\b",
            "end": "\\?>",
            "name": "comment"
        },
        "import": {
            "patterns": [
                {
                    "match": "(<\\?import)\\s+([a-zA-Z][a-zA-Z0-9.]*)(\\*?)(\\s*\\?>)",
                    "captures": {
                        "1": { "name": "comment" },
                        "2": { "name": "keyword" },
                        "3": { "name": "keyword" },
                        "4": { "name": "comment" }
                    }
                }
            ]
        },
        "comments": {
            "begin": "<!--",
            "end": "-->",
            "name": "comment"
        },
        "cdata": {
            "begin": "<!\\[CDATA\\[",
            "end": "\\]\\]>",
            "name": "string"
        },
        "fx-attr": {
            "patterns": [
                {
                    "match": "(fx:[a-zA-Z0-9]+)(\\s*=\\s*)(\"[^\"]*\")",
                    "captures": {
                        "1": { "name": "keyword" },
                        "2": { "name": "comment" },
                        "3": { "name": "string" }
                    }
                }
            ]
        },
        "event-handler-attr": {
            "patterns": [
                {
                    "match": "(on[A-Z][a-zA-Z0-9]*)(\\s*=\\s*)(\"[^\"]*\")",
                    "captures": {
                        "1": { "name": "support.function" },
                        "2": { "name": "comment" },
                        "3": { "name": "string" }
                    }
                }
            ]
        },
        "generic-attr": {
            "patterns": [
                {
                    "match": "([a-zA-Z][a-zA-Z0-9:.]*)(\\s*=\\s*)(\"[^\"]*\")",
                    "captures": {
                        "1": { "name": "variable" },
                        "2": { "name": "comment" },
                        "3": { "name": "string" }
                    }
                }
            ]
        },
        "fx-tag": {
            "patterns": [
                {
                    "match": "(</?)(fx:[a-zA-Z]+)",
                    "captures": {
                        "1": { "name": "comment" },
                        "2": { "name": "keyword" }
                    }
                }
            ]
        },
        "class-tag": {
            "patterns": [
                {
                    "match": "(</?)(([A-Z][A-Za-z0-9]*\\.)*[A-Z][A-Za-z0-9]*)",
                    "captures": {
                        "1": { "name": "comment" },
                        "2": { "name": "entity.name.type" }
                    }
                }
            ]
        },
        "property-tag": {
            "patterns": [
                {
                    "match": "(</?)(([A-Z][A-Za-z0-9]*\\.)*[a-z][a-zA-Z0-9]*)",
                    "captures": {
                        "1": { "name": "comment" },
                        "2": { "name": "entity.name.tag" }
                    }
                }
            ]
        },
        "tag-punctuation": {
            "patterns": [
                {
                    "match": "/?>",
                    "name": "comment"
                }
            ]
        }
    }
}

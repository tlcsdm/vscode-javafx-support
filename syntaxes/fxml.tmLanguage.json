{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "FXML",
    "scopeName": "source.fxml",
    "patterns": [
        { "include": "#fxmlImport" },
        { "include": "#xmlProcessingInstruction" },
        { "include": "#comment" },
        { "include": "#cdata" },
        { "include": "#closeFxTag" },
        { "include": "#closeClassTag" },
        { "include": "#closePropertyTag" },
        { "include": "#fxTag" },
        { "include": "#classTag" },
        { "include": "#propertyTag" }
    ],
    "repository": {
        "xmlProcessingInstruction": {
            "begin": "<\\?",
            "end": "\\?>",
            "name": "meta.tag.preprocessor.fxml",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.tag.begin.fxml" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.tag.end.fxml" }
            },
            "patterns": [
                {
                    "match": "\\b(xml|language)\\b",
                    "name": "entity.name.tag.fxml"
                },
                { "include": "#attribute" }
            ]
        },
        "fxmlImport": {
            "match": "(<\\?)(import)\\s+([\\w\\.]+)(\\*?)\\s*(\\?>)",
            "captures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "2": { "name": "keyword.control.import.fxml" },
                "3": { "name": "entity.name.type.import.fxml" },
                "4": { "name": "keyword.operator.wildcard.fxml" },
                "5": { "name": "punctuation.definition.tag.end.fxml" }
            }
        },
        "comment": {
            "begin": "<!--",
            "end": "-->",
            "name": "comment.block.fxml"
        },
        "cdata": {
            "begin": "<!\\[CDATA\\[",
            "end": "\\]\\]>",
            "name": "string.unquoted.cdata.fxml"
        },
        "fxTag": {
            "begin": "(<)(fx:(?:include|define|copy|root|script|reference))",
            "end": "(/?>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "2": { "name": "keyword.control.fxml" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.end.fxml" }
            },
            "patterns": [
                { "include": "#fxAttribute" },
                { "include": "#eventHandlerAttribute" },
                { "include": "#attribute" }
            ]
        },
        "closeFxTag": {
            "match": "(</)(fx:(?:include|define|copy|root|script|reference))(>)",
            "captures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "2": { "name": "keyword.control.fxml" },
                "3": { "name": "punctuation.definition.tag.end.fxml" }
            }
        },
        "classTag": {
            "begin": "(<)(([\\w\\.]+:)?([A-Z][\\w\\.]*))",
            "end": "(/?>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "3": { "name": "entity.name.tag.namespace.fxml" },
                "4": { "name": "entity.name.type.class.fxml" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.end.fxml" }
            },
            "patterns": [
                { "include": "#fxAttribute" },
                { "include": "#eventHandlerAttribute" },
                { "include": "#xmlnsAttribute" },
                { "include": "#staticPropertyAttribute" },
                { "include": "#attribute" }
            ]
        },
        "propertyTag": {
            "begin": "(<)(([\\w\\.]+:)?([a-z][\\w\\.]*))",
            "end": "(/?>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "3": { "name": "entity.name.tag.namespace.fxml" },
                "4": { "name": "entity.name.tag.fxml" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.end.fxml" }
            },
            "patterns": [
                { "include": "#fxAttribute" },
                { "include": "#eventHandlerAttribute" },
                { "include": "#xmlnsAttribute" },
                { "include": "#staticPropertyAttribute" },
                { "include": "#attribute" }
            ]
        },
        "closeClassTag": {
            "match": "(</)([\\w\\.]+:)?([A-Z][\\w\\.]*)(>)",
            "captures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "2": { "name": "entity.name.tag.namespace.fxml" },
                "3": { "name": "entity.name.type.class.fxml" },
                "4": { "name": "punctuation.definition.tag.end.fxml" }
            }
        },
        "closePropertyTag": {
            "match": "(</)([\\w\\.]+:)?([a-z][\\w\\.]*)(>)",
            "captures": {
                "1": { "name": "punctuation.definition.tag.begin.fxml" },
                "2": { "name": "entity.name.tag.namespace.fxml" },
                "3": { "name": "entity.name.tag.fxml" },
                "4": { "name": "punctuation.definition.tag.end.fxml" }
            }
        },
        "fxAttribute": {
            "match": "(fx:\\w+)\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": { "name": "keyword.control.fxml" },
                "2": { "name": "punctuation.separator.key-value.fxml" },
                "3": { "name": "string.quoted.double.fxml" }
            }
        },
        "eventHandlerAttribute": {
            "match": "(on\\w+)\\s*(=)\\s*(\"(#[\\w]+)\"|'(#[\\w]+)')",
            "captures": {
                "1": { "name": "support.function.event.fxml" },
                "2": { "name": "punctuation.separator.key-value.fxml" },
                "3": { "name": "string.quoted.double.fxml" },
                "4": { "name": "entity.name.function.event-handler.fxml" },
                "5": { "name": "entity.name.function.event-handler.fxml" }
            }
        },
        "xmlnsAttribute": {
            "match": "(xmlns(?::\\w+)?)\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": { "name": "entity.other.attribute-name.namespace.fxml" },
                "2": { "name": "punctuation.separator.key-value.fxml" },
                "3": { "name": "string.quoted.double.fxml" }
            }
        },
        "staticPropertyAttribute": {
            "match": "([A-Z][\\w]*\\.[\\w]+)\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": { "name": "entity.other.attribute-name.fxml" },
                "2": { "name": "punctuation.separator.key-value.fxml" },
                "3": { "name": "string.quoted.double.fxml" }
            }
        },
        "attribute": {
            "match": "([\\w\\-\\.]+(?::[\\w\\-\\.]+)?)\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": { "name": "entity.other.attribute-name.fxml" },
                "2": { "name": "punctuation.separator.key-value.fxml" },
                "3": { "name": "string.quoted.double.fxml" }
            }
        }
    }
}

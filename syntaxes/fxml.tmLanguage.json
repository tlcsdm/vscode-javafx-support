{
    "name": "FXML",
    "scopeName": "text.xml.fxml",
    "fileTypes": [
        "fxml"
    ],
    "patterns": [
        {
            "include": "#xml-decl"
        },
        {
            "include": "#language-decl"
        },
        {
            "include": "#import"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#cdata"
        },
        {
            "include": "#fx-tag"
        },
        {
            "include": "#class-tag"
        },
        {
            "include": "#close-class-tag"
        },
        {
            "include": "#property-tag"
        },
        {
            "include": "#close-property-tag"
        }
    ],
    "repository": {
        "xml-decl": {
            "patterns": [
                {
                    "begin": "<\\?xml",
                    "end": "\\?>",
                    "name": "comment"
                }
            ]
        },
        "language-decl": {
            "patterns": [
                {
                    "begin": "<\\?language",
                    "end": "\\?>",
                    "name": "comment"
                }
            ]
        },
        "import": {
            "patterns": [
                {
                    "match": "(<\\?import\\s+)([a-zA-Z][a-zA-Z0-9.]+?)(\\*?)(\\?>)",
                    "captures": {
                        "1": {
                            "name": "variable"
                        },
                        "2": {
                            "name": "keyword"
                        },
                        "3": {
                            "name": "storage.type.java"
                        },
                        "4": {
                            "name": "variable"
                        }
                    }
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "begin": "<!--",
                    "end": "-->",
                    "name": "comment"
                }
            ]
        },
        "cdata": {
            "patterns": [
                {
                    "begin": "<!\\[CDATA\\[",
                    "end": "\\]\\]>",
                    "name": "string"
                }
            ]
        },
        "fx-attr": {
            "patterns": [
                {
                    "match": "(fx:\\w+)(\\s*=\\s*)(\"[^\"]*\"|'[^']*')",
                    "captures": {
                        "1": {
                            "name": "keyword"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "string"
                        }
                    }
                }
            ]
        },
        "event-handler-attr": {
            "patterns": [
                {
                    "match": "(on\\w+)(\\s*=\\s*)(\"[^\"]*\"|'[^']*')",
                    "captures": {
                        "1": {
                            "name": "support.function"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "string"
                        }
                    }
                }
            ]
        },
        "generic-attr": {
            "patterns": [
                {
                    "match": "([\\w\\-.:]+)(\\s*=\\s*)(\"[^\"]*\"|'[^']*')",
                    "captures": {
                        "1": {
                            "name": "variable"
                        },
                        "2": {
                            "name": "comment"
                        },
                        "3": {
                            "name": "string"
                        }
                    }
                }
            ]
        },
        "fx-tag": {
            "patterns": [
                {
                    "begin": "(<)(fx:\\w+)",
                    "end": "(/?>)",
                    "beginCaptures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "keyword"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "comment"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#fx-attr"
                        },
                        {
                            "include": "#event-handler-attr"
                        },
                        {
                            "include": "#generic-attr"
                        }
                    ]
                },
                {
                    "match": "(</)(fx:\\w+)(>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "keyword"
                        },
                        "3": {
                            "name": "comment"
                        }
                    }
                }
            ]
        },
        "class-tag": {
            "patterns": [
                {
                    "begin": "(<)([A-Z][\\w.]*)",
                    "end": "(/?>)",
                    "beginCaptures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "entity.name.type"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "comment"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#fx-attr"
                        },
                        {
                            "include": "#event-handler-attr"
                        },
                        {
                            "include": "#generic-attr"
                        }
                    ]
                }
            ]
        },
        "close-class-tag": {
            "patterns": [
                {
                    "match": "(</)([A-Z][\\w.]*)(>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "entity.name.type"
                        },
                        "3": {
                            "name": "comment"
                        }
                    }
                }
            ]
        },
        "property-tag": {
            "patterns": [
                {
                    "begin": "(<)([a-z][\\w.]*)",
                    "end": "(/?>)",
                    "beginCaptures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "entity.name.tag"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "comment"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#fx-attr"
                        },
                        {
                            "include": "#event-handler-attr"
                        },
                        {
                            "include": "#generic-attr"
                        }
                    ]
                }
            ]
        },
        "close-property-tag": {
            "patterns": [
                {
                    "match": "(</)([a-z][\\w.]*)(>)",
                    "captures": {
                        "1": {
                            "name": "comment"
                        },
                        "2": {
                            "name": "entity.name.tag"
                        },
                        "3": {
                            "name": "comment"
                        }
                    }
                }
            ]
        }
    }
}

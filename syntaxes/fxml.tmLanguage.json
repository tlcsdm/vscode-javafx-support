{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "FXML",
    "scopeName": "text.xml.fxml",
    "patterns": [
        { "include": "#xmlProcessingInstruction" },
        { "include": "#languageProcessingInstruction" },
        { "include": "#fxmlImport" },
        { "include": "#comment" },
        { "include": "#cdata" },
        { "include": "#tag" }
    ],
    "repository": {
        "xmlProcessingInstruction": {
            "begin": "<\\?xml",
            "end": "\\?>",
            "name": "meta.tag.preprocessor.xml.fxml",
            "patterns": [
                { "include": "#attribute" }
            ]
        },
        "languageProcessingInstruction": {
            "begin": "<\\?language",
            "end": "\\?>",
            "name": "meta.tag.preprocessor.xml.fxml",
            "patterns": [
                { "include": "#attribute" }
            ]
        },
        "fxmlImport": {
            "match": "(<\\?import\\s+)([a-zA-Z][a-zA-Z0-9.]+?)(\\*?)(\\s*\\?>)",
            "name": "meta.tag.preprocessor.import.fxml",
            "captures": {
                "1": { "name": "keyword.control.import.fxml" },
                "2": { "name": "entity.name.type.import.fxml" },
                "3": { "name": "storage.type.wildcard.fxml" },
                "4": { "name": "keyword.control.import.fxml" }
            }
        },
        "comment": {
            "patterns": [
                {
                    "match": "<!--[^-]*-->",
                    "name": "comment.block.xml.fxml"
                },
                {
                    "begin": "<!--",
                    "end": "-->",
                    "name": "comment.block.xml.fxml"
                }
            ]
        },
        "cdata": {
            "begin": "<!\\[CDATA\\[",
            "end": "\\]\\]>",
            "name": "string.unquoted.cdata.xml.fxml"
        },
        "tag": {
            "patterns": [
                { "include": "#propertyTag" },
                { "include": "#classTag" },
                { "include": "#closePropertyTag" },
                { "include": "#closeClassTag" }
            ]
        },
        "classTag": {
            "begin": "(<)([A-Z][\\w\\.]*)",
            "end": "(/?>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.begin.xml.fxml" },
                "2": { "name": "entity.name.tag.class.xml.fxml" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.end.xml.fxml" }
            },
            "patterns": [
                { "include": "#fxAttribute" },
                { "include": "#eventHandlerAttribute" },
                { "include": "#attribute" }
            ]
        },
        "propertyTag": {
            "begin": "(<)([a-z][\\w\\.]*)",
            "end": "(/?>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.tag.begin.xml.fxml" },
                "2": { "name": "entity.name.tag.property.xml.fxml" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.tag.end.xml.fxml" }
            },
            "patterns": [
                { "include": "#fxAttribute" },
                { "include": "#eventHandlerAttribute" },
                { "include": "#attribute" }
            ]
        },
        "closeClassTag": {
            "match": "(</)([A-Z][\\w\\.]*)(>)",
            "captures": {
                "1": { "name": "punctuation.definition.tag.begin.xml.fxml" },
                "2": { "name": "entity.name.tag.class.xml.fxml" },
                "3": { "name": "punctuation.definition.tag.end.xml.fxml" }
            }
        },
        "closePropertyTag": {
            "match": "(</)([a-z][\\w\\.]*)(>)",
            "captures": {
                "1": { "name": "punctuation.definition.tag.begin.xml.fxml" },
                "2": { "name": "entity.name.tag.property.xml.fxml" },
                "3": { "name": "punctuation.definition.tag.end.xml.fxml" }
            }
        },
        "fxAttribute": {
            "match": "(fx:(id|controller|value|factory|constant|reference|include|define|copy|root))\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": { "name": "entity.other.attribute-name.namespace.xml.fxml support.type.fxml" },
                "3": { "name": "punctuation.separator.key-value.xml.fxml" },
                "4": { "name": "string.quoted.double.xml.fxml" }
            }
        },
        "eventHandlerAttribute": {
            "match": "(on\\w+)\\s*(=)\\s*(\"(#[\\w]+)\"|'(#[\\w]+)')",
            "captures": {
                "1": { "name": "entity.other.attribute-name.xml.fxml support.function.event.fxml" },
                "2": { "name": "punctuation.separator.key-value.xml.fxml" },
                "3": { "name": "string.quoted.double.xml.fxml" },
                "4": { "name": "entity.name.function.event-handler.fxml" },
                "5": { "name": "entity.name.function.event-handler.fxml" }
            }
        },
        "attribute": {
            "match": "([\\w\\-\\.]+(?::[\\w\\-\\.]+)?)\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": { "name": "entity.other.attribute-name.xml.fxml" },
                "2": { "name": "punctuation.separator.key-value.xml.fxml" },
                "3": { "name": "string.quoted.double.xml.fxml" }
            }
        }
    }
}
